# ----------------------------
# Python / venv
# ----------------------------
.venv/
venv/
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
dist/
build/

# ----------------------------
# Jupyter
# ----------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ----------------------------
# Data (do not commit datasets)
# ----------------------------
*.csv
*.parquet
*.feather
*.pkl
*.pickle
*.joblib
*.sqlite
*.db
# Keep folder placeholders
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# ----------------------------
# Reports / artifacts
# ----------------------------
reports/*.html
reports/*.pdf
reports/tmp/

# If you want to KEEP figures in git for interview-readiness, comment out the above block.

